#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = [
#     "click>=8",
#     "httpx>=0.27",
#     "PyYAML>=6",
# ]
# ///
"""clashctl - control local mihomo proxy via external-controller API.

Subcommands persist mode and per-group selections to the YAML config so that
changes survive `systemctl restart clash` and subscription refresh.

Environment overrides:
  CLASH_API   default http://127.0.0.1:9090
  CLASH_YAML  default $HOME/clash/AgentNEO_wLUA.yaml
"""
from __future__ import annotations

import concurrent.futures
import os
import re
import subprocess
import sys
import urllib.parse
from pathlib import Path

import click
import httpx
import yaml

API = os.environ.get("CLASH_API", "http://127.0.0.1:9090")
YAML_PATH = Path(
    os.environ.get("CLASH_YAML", str(Path.home() / "clash" / "AgentNEO_wLUA.yaml"))
)
GROUP_TYPES = ("Selector", "URLTest", "Fallback", "LoadBalance")
# Synthetic / built-in proxies exposed by the API that aren't real upstream nodes.
_BUILTIN_PROXIES = ("Direct", "Reject", "RejectDrop", "Pass", "Compatible")

# mihomo emits logfmt lines like:
#   time="2026-05-11T13:13:42.144+08:00" level=info msg="..."
_LOG_LINE = re.compile(r'^time="([^"]+)" level=(\w+) msg="(.*)"\s*$')
_LEVEL_FG = {
    "debug": "bright_black",
    "info": "cyan",
    "warn": "yellow",
    "warning": "yellow",
    "error": "red",
    "fatal": "bright_red",
}


def _request(method: str, path: str, json_body: dict | None = None):
    url = f"{API}{path}"
    try:
        r = httpx.request(method, url, json=json_body, timeout=5.0)
        r.raise_for_status()
        return r.json() if r.content else None
    except httpx.HTTPError as e:
        click.echo(f"API error ({method} {url}): {e}", err=True)
        sys.exit(1)


def _enc(name: str) -> str:
    return urllib.parse.quote(name, safe="")


def _yaml_load() -> dict:
    with YAML_PATH.open() as f:
        return yaml.safe_load(f) or {}


def _yaml_save(data: dict) -> None:
    with YAML_PATH.open("w") as f:
        yaml.safe_dump(
            data, f, allow_unicode=True, sort_keys=False, default_flow_style=False
        )


@click.group(context_settings={"help_option_names": ["-h", "--help"]})
@click.version_option("0.1.0", "-V", "--version")
def cli():
    """Control local mihomo proxy."""


@cli.command()
def info():
    """Show version, mode and ports."""
    v = _request("GET", "/version")
    c = _request("GET", "/configs")
    click.echo(f"mihomo {v.get('version')}  meta={v.get('meta')}")
    for k in ("mode", "log-level", "port", "socks-port", "mixed-port"):
        click.echo(f"  {k:14} {c.get(k)}")


@cli.command()
def groups():
    """List proxy groups with current selection."""
    d = _request("GET", "/proxies")["proxies"]
    for name, info in d.items():
        if info["type"] in GROUP_TYPES:
            now = info.get("now", "-")
            n = len(info.get("all", []))
            click.echo(f"{info['type']:9} {name:<22} → {now:<28} ({n} nodes)")


@cli.command()
@click.argument("group", required=False)
def proxies(group):
    """List nodes inside a group, or every individual proxy when no group is given.

    Without arguments: lists all concrete proxies (Trojan / Shadowsocks /
    VMess / etc., excluding groups and the synthetic Direct / Reject) with
    their type and last-known delay.
    """
    if group:
        d = _request("GET", f"/proxies/{_enc(group)}")
        click.echo(f"{d['name']} ({d['type']}) → {d.get('now', '-')}")
        for p in d.get("all", []):
            click.echo((" → " if p == d.get("now") else "   ") + p)
        return

    data = _request("GET", "/proxies")["proxies"]
    rows = []
    for name, info in data.items():
        t = info["type"]
        if t in GROUP_TYPES or t in _BUILTIN_PROXIES:
            continue
        history = info.get("history", [])
        last = f"{history[-1].get('delay', 0)} ms" if history else "-"
        rows.append((t, name, last))
    rows.sort()
    for t, name, last in rows:
        click.echo(f"  {t:<12} {name:<36} {last}")


@cli.command()
@click.argument("group")
@click.argument("node")
def select(group, node):
    """Switch a group to a specific node (persistent)."""
    _request("PUT", f"/proxies/{_enc(group)}", json_body={"name": node})
    data = _yaml_load()
    for pg in data.get("proxy-groups", []):
        if pg.get("name") == group:
            ps = pg.get("proxies", [])
            if node in ps:
                ps.remove(node)
                ps.insert(0, node)
                pg["proxies"] = ps
                _yaml_save(data)
            else:
                click.echo(
                    f"warning: '{node}' not listed in group '{group}' (api applied, yaml unchanged)",
                    err=True,
                )
            break
    else:
        click.echo(
            f"warning: group '{group}' not found in yaml (api applied, yaml unchanged)",
            err=True,
        )
    click.echo(f"selected: {group} → {node}")


@cli.command()
@click.argument("new_mode", required=False)
def mode(new_mode):
    """Show or set routing mode (Rule | Global | Direct). Persistent."""
    if not new_mode:
        click.echo(_request("GET", "/configs")["mode"])
        return
    _request("PATCH", "/configs", json_body={"mode": new_mode})
    data = _yaml_load()
    data["mode"] = new_mode
    _yaml_save(data)
    click.echo(f"mode set to: {new_mode}")


@cli.command()
def reload():
    """Reload config from yaml on disk."""
    _request("PUT", "/configs", json_body={"path": str(YAML_PATH)})
    click.echo(f"reloaded from {YAML_PATH}")


@cli.command(context_settings={"ignore_unknown_options": True, "allow_extra_args": True})
@click.option("--raw", is_flag=True, help="Pass journalctl output through unmodified.")
@click.pass_context
def logs(ctx, raw):
    """Tail clash systemd logs.

    Default: strip journalctl's hostname/PID prefix, parse mihomo's logfmt,
    show only HH:MM:SS, colorize by level. Use --raw to disable formatting
    (e.g. when piping into another tool that wants the original format).

    Any extra args are passed to journalctl, e.g.::

        clashctl logs -n 50
        clashctl logs -f
        clashctl logs --since "10 min ago"
        clashctl logs --grep REJECT
    """
    extra = list(ctx.args)
    base = ["sudo", "journalctl", "-u", "clash.service"]
    if raw:
        os.execvp(base[0], base + extra)

    cmd = base + ["--output=cat", *extra]
    proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, text=True, bufsize=1)
    try:
        assert proc.stdout is not None
        for line in proc.stdout:
            line = line.rstrip("\n")
            m = _LOG_LINE.match(line)
            if not m:
                click.echo(line)
                continue
            ts, level, msg = m.groups()
            hms = ts[11:19] if len(ts) >= 19 else ts
            level_styled = click.style(f"{level:<7}", fg=_LEVEL_FG.get(level))
            click.echo(f"{hms} {level_styled} {msg}")
    except (KeyboardInterrupt, BrokenPipeError):
        pass
    finally:
        proc.terminate()
        try:
            proc.wait(timeout=1)
        except subprocess.TimeoutExpired:
            proc.kill()
        sys.exit(proc.returncode or 0)


@cli.command()
@click.argument("url", required=False, default="https://ipinfo.io/ip")
def test(url):
    """Compare proxied vs direct fetch."""
    for label, proxy_args in (("PROXY ", ["-x", "http://127.0.0.1:7890"]), ("DIRECT", [])):
        try:
            r = subprocess.run(
                ["curl", "-sS", "--max-time", "6", *proxy_args, url],
                capture_output=True,
                text=True,
                timeout=8,
            )
            click.echo(f"{label}: {r.stdout.strip() or '(empty)'}")
        except Exception as e:
            click.echo(f"{label}: (failed: {e})")


def _delay_one(name: str, timeout_ms: int = 3000) -> int:
    """Probe one concrete proxy. Returns delay in ms, or 0 on failure."""
    try:
        r = httpx.get(
            f"{API}/proxies/{_enc(name)}/delay",
            params={
                "url": "https://www.gstatic.com/generate_204",
                "timeout": timeout_ms,
            },
            timeout=(timeout_ms / 1000) + 2,
        )
        if r.status_code == 200:
            return r.json().get("delay", 0)
    except Exception:
        pass
    return 0


@cli.command()
@click.argument("group", required=False)
def delay(group):
    """Measure delay of nodes in a group, or every concrete proxy without arg.

    Without arguments: probes every individual proxy in parallel (8 workers)
    and prints results sorted fastest-first; timeouts appear at the end with
    `0 ms`.
    """
    if group:
        test_url = urllib.parse.quote(
            "https://www.gstatic.com/generate_204", safe=""
        )
        d = _request(
            "GET", f"/group/{_enc(group)}/delay?url={test_url}&timeout=3000"
        )
    else:
        data = _request("GET", "/proxies")["proxies"]
        concrete = [
            n
            for n, info in data.items()
            if info["type"] not in GROUP_TYPES
            and info["type"] not in _BUILTIN_PROXIES
        ]
        if not concrete:
            click.echo("no concrete proxies found", err=True)
            return
        d = {}
        with concurrent.futures.ThreadPoolExecutor(max_workers=8) as pool:
            futures = {pool.submit(_delay_one, n): n for n in concrete}
            for fut in concurrent.futures.as_completed(futures):
                d[futures[fut]] = fut.result()

    for name, ms in sorted(d.items(), key=lambda x: (x[1] == 0, x[1])):
        click.echo(f"  {ms:>5} ms   {name}")


def _systemctl(action: str) -> None:
    """Delegate to systemctl on clash.service. Uses sudo for state changes."""
    if action == "status":
        cmd = ["systemctl", action, "clash.service", "--no-pager"]
    else:
        cmd = ["sudo", "systemctl", action, "clash.service"]
    os.execvp(cmd[0], cmd)


@cli.command()
def start():
    """Start clash systemd service (sudo systemctl start clash)."""
    _systemctl("start")


@cli.command()
def stop():
    """Stop clash systemd service (sudo systemctl stop clash)."""
    _systemctl("stop")


@cli.command()
def restart():
    """Restart clash systemd service (sudo systemctl restart clash)."""
    _systemctl("restart")


@cli.command()
def status():
    """Show clash systemd service status (systemctl status clash)."""
    _systemctl("status")


if __name__ == "__main__":
    cli()
